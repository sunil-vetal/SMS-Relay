<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:id="@+id/settingsTopBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/surface"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:elevation="2dp">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Settings"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── General ─────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Include sender &amp; time"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary" />
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchIncludeSender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="Only forward from (optional)"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editFilterSender"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="phone" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Relay Options ────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RELAY OPTIONS"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="16dp" />

                    <!-- Row 1: Email · WhatsApp · G.Voice -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardEmail"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/divider">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_email_provider" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email" android:textSize="12sp" android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardWhatsApp"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/divider">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_whatsapp_provider" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WhatsApp" android:textSize="12sp" android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardGVoice"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/divider">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_gvoice_provider" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="G.Voice" android:textSize="12sp" android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 2: Telegram · ntfy · Discord -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardTelegram"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/divider">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_telegram_provider" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Telegram" android:textSize="12sp" android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardNtfy"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/divider">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_ntfy_provider" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ntfy" android:textSize="12sp" android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDiscord"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/divider">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_discord_provider" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Discord" android:textSize="12sp" android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 3: Google Chat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardGChat"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="6dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/divider">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">
                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_gchat_provider" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="G.Chat" android:textSize="12sp" android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:layout_marginEnd="8dp" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    </LinearLayout>

                    <!-- Dynamic config panel title -->
                    <TextView
                        android:id="@+id/tvPanelTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email (SMTP) Settings"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp" />

                    <!-- ── Email Panel ── -->
                    <LinearLayout android:id="@+id/panelEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Recipient Email">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editEmailRecipient" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textEmailAddress" /></com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="SMTP Host (e.g. smtp.gmail.com)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editSmtpHost" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" /></com.google.android.material.textfield.TextInputLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="12dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Port">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/editSmtpPort" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" /></com.google.android.material.textfield.TextInputLayout>
                            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchSmtpSsl" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SSL" android:textSize="13sp" />
                        </LinearLayout>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Gmail / SMTP Username">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editSmtpUser" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textEmailAddress" /></com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="App Password" app:endIconMode="password_toggle">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editSmtpPass" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textPassword" /></com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- ── WhatsApp Panel ── -->
                    <LinearLayout android:id="@+id/panelWhatsApp" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Opens WhatsApp with pre-filled message. Screen must be on." android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="8dp" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="WhatsApp number (e.g. +14155552671)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editWaNumber" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" /></com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- ── Google Voice Panel ── -->
                    <LinearLayout android:id="@+id/panelGVoice" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Relays SMS to your GV number via carrier SMS." android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="8dp" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Google Voice number (e.g. +12025551234)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editGvNumber" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" /></com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- ── Telegram Panel ── -->
                    <LinearLayout android:id="@+id/panelTelegram" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Setup: message @BotFather → /newbot → get token. Send a message to your bot, then get your chat ID from https://api.telegram.org/bot{TOKEN}/getUpdates" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="8dp" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Bot Token (e.g. 123456:ABC-DEF...)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editTelegramToken" android:layout_width="match_parent" android:layout_height="wrap_content" /></com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Chat ID (e.g. -123456789)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editTelegramChatId" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberSigned" /></com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- ── ntfy Panel ── -->
                    <LinearLayout android:id="@+id/panelNtfy" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Free push notifications. Install ntfy app → subscribe to your topic. Use a random topic name for privacy." android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="8dp" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Topic name (e.g. my-sms-abc123)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editNtfyTopic" android:layout_width="match_parent" android:layout_height="wrap_content" /></com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Server (default: https://ntfy.sh)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editNtfyServer" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" /></com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- ── Discord Panel ── -->
                    <LinearLayout android:id="@+id/panelDiscord" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Setup: Discord server → channel → Edit → Integrations → Webhooks → New Webhook → Copy URL" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="8dp" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Webhook URL (https://discord.com/api/webhooks/...)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editDiscordWebhook" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" /></com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- ── Google Chat Panel ── -->
                    <LinearLayout android:id="@+id/panelGChat" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Setup: Google Chat Space → Apps &amp; integrations → Webhooks → Add Webhook → Copy URL" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="8dp" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:hint="Webhook URL (https://chat.googleapis.com/...)">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/editGChatWebhook" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" /></com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Test + Apply inside Relay Options card -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTestForward"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Send Test Message"
                        android:textAllCaps="false"
                        android:textColor="@color/primary"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSave"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:text="Apply Settings"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Permissions ──────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="System Permissions" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/tvPermStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Checking..." android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginBottom="16dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnGrantPerms" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Review Permissions" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textAllCaps="false" app:strokeColor="@color/primary" android:textColor="@color/primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── About ─────────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="About Relay" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginBottom="4dp" />
